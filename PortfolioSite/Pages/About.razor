@page "/about"

<PageTitle>About</PageTitle>

<h1 class="page-heading">About Me</h1>

<div class="row g-5 mt-1">
    <div class="col-lg-4 text-center">
        <div class="profile-photo-placeholder mb-3">
            <span>&#128100;</span>
        </div>
        <h3>Your Name</h3>
        <p class="text-muted">Game Development Student</p>
        <p class="text-muted mb-1">Neumont University</p>
        <p class="text-muted">Salt Lake City, UT</p>
    </div>

    <div class="col-lg-8">
        <h4>Who I Am</h4>
        <p>
            I'm a game development student at Neumont University with a passion for creating
            immersive interactive experiences. I love everything from early prototyping and
            game feel to level design and narrative systems.
        </p>
        <p>
            When I'm not building games, I'm most defintely playing them — always studying what makes a
            design work. I believe great games come from curiosity, iteration, and
            a relentless focus on the player's experience.
        </p>

        <h4 class="mt-4">Education</h4>
        <div class="education-entry">
            <strong>Bachelor of Science in Game Development</strong>
            <span class="text-muted ms-2">Neumont University</span>
            <div class="text-muted small">Salt Lake City, UT &mdash; Expected Graduation: 2026</div>
        </div>

        <h4 class="mt-4">Skills</h4>
        <div class="skills-grid">
            <div class="skill-group">
                <h6>Engines &amp; Tools</h6>
                <div class="skill-tags">
                    <span class="skill-tag">Unity</span>
                    <span class="skill-tag">Unreal Engine 5</span>
                    <span class="skill-tag">GameMaker</span>
                    <span class="skill-tag">Visual Studio</span>
                </div>
            </div>
            <div class="skill-group mt-3">
                <h6>Languages</h6>
                <div class="skill-tags">
                    <span class="skill-tag">C#</span>
                    <span class="skill-tag">C++</span>
                    <span class="skill-tag">Python</span>
                    <span class="skill-tag">Java</span>
                </div>
            </div>
            <div class="skill-group mt-3">
                <h6>Game Dev Disciplines</h6>
                <div class="skill-tags">
                    <span class="skill-tag">Gameplay Systems</span>
                    <span class="skill-tag">Front End</span>
                    <span class="skill-tag">Prototyping</span>
                    <span class="skill-tag">Gimmicks</span>
                    <span class="skill-tag">AI Behavior</span>
                </div>
            </div>
        </div>
    </div>
</div>
