@page "/"

<PageTitle>Home</PageTitle>

<div class="hero-section">
    <div class="hero-content">
        <p class="hero-subtitle">Hi, I'm</p>
        <h1 class="hero-name">Andrew Jacoboski</h1>
        <p class="hero-tagline">Game Development Student at Neumont University</p>
        <p class="hero-description">
            I create games — from prototypes to experinces.
            Passionate about gameplay systems, player experince, and pushing what games can be.
        </p>
        <div class="hero-actions">
            <a href="projects" class="btn btn-primary btn-lg me-3">View My Projects</a>
            <a href="about" class="btn btn-outline-secondary btn-lg">About Me</a>
        </div>
    </div>
</div>

<div class="skills-strip">
    <span class="skill-badge">Unity</span>
    <span class="skill-badge">Unreal Engine</span>
    <span class="skill-badge">C#</span>
    <span class="skill-badge">C++</span>
    <span class="skill-badge">GameMaker</span>
    <span class="skill-badge">Front End</span>
</div>

<div class="home-cards row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 home-card">
            <div class="card-body">
                <div class="home-card-icon">&#127918;</div>
                <h5 class="card-title">Projects</h5>
                <p class="card-text">Check out the games I've built.</p>
                <a href="projects" class="btn btn-sm btn-primary mt-2">See Projects</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 home-card">
            <div class="card-body">
                <div class="home-card-icon">&#128100;</div>
                <h5 class="card-title">About Me</h5>
                <p class="card-text">Learn about my background, skills, and what drives me as a developer.</p>
                <a href="about" class="btn btn-sm btn-primary mt-2">Learn More</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 home-card">
            <div class="card-body">
                <div class="home-card-icon">&#128140;</div>
                <h5 class="card-title">Contact</h5>
                <p class="card-text">Interested in contacting me? I'd love to hear from you.</p>
                <a href="contact" class="btn btn-sm btn-primary mt-2">Get in Touch</a>
            </div>
        </div>
    </div>
</div>
