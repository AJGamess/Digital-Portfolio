@page "/contact"

<PageTitle>Contact</PageTitle>

<h1 class="page-heading">Contact</h1>
<p class="text-muted mb-4">Have a project in mind, or just want to say hi? Reach out!</p>

<div class="row g-5">
    <div class="col-lg-5">
        <h5>Get in Touch</h5>
        <p class="text-muted">
            I'm always open to internship opportunities, or just
            talking about games and design.
        </p>

        <div class="contact-link-item">
            <span class="contact-icon">&#128140;</span>
            <a href="mailto:jacoboskiaaa969@gmail.com">Email</a>
        </div>
        <div class="contact-link-item">
            <span class="contact-icon">&#128279;</span>
            <a href="https://github.com/AJGamess" target="_blank">Github</a>
        </div>
        <div class="contact-link-item">
            <span class="contact-icon">&#128101;</span>
            <a href="https://linkedin.com/in/yourusername" target="_blank">LinkedIn</a>
        </div>
        <div class="contact-link-item">
            <span class="contact-icon">&#127918;</span>
            <a href="https://ajgamess.itch.io/" target="_blank">Itch.io</a>
        </div>
    </div>

    <div class="col-lg-7">
        @if (submitted)
        {
            <div class="alert alert-success" role="alert">
                <strong>Message sent!</strong> Thanks for reaching out — I'll get back to you soon.
            </div>
        }
        else
        {
            <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="formModel.Name" placeholder="Your name" />
                    <ValidationMessage For="() => formModel.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="formModel.Email" placeholder="you@example.com" />
                    <ValidationMessage For="() => formModel.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Message</label>
                    <InputTextArea class="form-control" @bind-Value="formModel.Message" rows="5" placeholder="What's on your mind?" />
                    <ValidationMessage For="() => formModel.Message" />
                </div>
                <button type="submit" class="btn btn-primary">Send Message</button>
            </EditForm>
        }
    </div>
</div>

@code {
    private ContactForm formModel = new();
    private bool submitted = false;

    private void HandleSubmit()
    {
        submitted = true;
    }

    public class ContactForm
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(10)]
        public string Message { get; set; } = "";
    }
}
